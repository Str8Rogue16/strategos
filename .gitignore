# --- STRATEGOS DATA SOVEREIGNTY ---
# Do not track the Vault where sensitive strategy logs or 
# observation sets are stored locally.
vault/
*.log

# --- SECRETS & AUTH ---
# Protect your API keys and local environment variables
.env
.env.local
.env.development.local

# --- LOCAL PROXY / SYSTEM ---
# Ignore the local proxy artifacts or node modules if you add them
node_modules/
dist/
.DS_Store
Thumbs.db

# --- IDE CONFIG ---
# Don't leak your personal workflow settings
.vscode/
.idea/
*.swp
